{
  "name": "snack-stock-manager",
  "version": "1.0.0",
  "description": "REST API for a snack stock manager",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "seed": "node prisma/seed.js",
    "format": "prettier --write \"src/**/*.js\" \"prisma/**/*.js\""
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prisma": "^6.19.3"
  },
  "allowScripts": {
    "bcrypt@5.1.1": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true
  }
}
